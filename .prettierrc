{
    "overrides": [
        {
            "files": "*.wxml",
            "options": {
                "parser": "html"
            }
        },
        {
            "files": "*.wxss",
            "options": {
                "parser": "css"
            }
        },
        {
            "files": "*.wxs",
            "options": {
                "parser": "babel"
            }
        }
    ],
    "printWidth": 100,
    "htmlWhitespaceSensitivity": "strict",
    "tabWidth": 2,
    "useTabs": false,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5",
    "bracketSpacing": true
}